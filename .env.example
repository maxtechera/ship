# ship — environment variables
# Copy this file to .env and fill in values as needed.
# All variables are optional — defaults work for most setups.

# ── credentials skill ─────────────────────────────────────────────────────────
# Directory where token files live (default: ~/.clawdbot)
# SHIP_CRED_DIR=~/.config/ship/credentials

# Directory for additional YAML check definitions (default: $SHIP_CRED_DIR/extensions)
# SHIP_EXTENSIONS_DIR=~/.config/ship/extensions

# ── ship-engine ───────────────────────────────────────────────────────────────
# Where active run state is stored (default: ship-engine/runs/)
# SHIP_RUNS_DIR=~/.local/share/ship/runs

# Where archived runs go (default: ship-engine/archive/)
# SHIP_ARCHIVE_DIR=~/.local/share/ship/archive

# Path to LEARNINGS.md lesson log (default: ship-engine/LEARNINGS.md)
# SHIP_LEARNINGS_PATH=~/.local/share/ship/LEARNINGS.md

# ── external APIs ─────────────────────────────────────────────────────────────
# Linear API key for run management (preferred over token file)
# LINEAR_API_KEY=lin_api_...

# Path to Linear token file (default: ~/.clawdbot/.linear_token)
# LINEAR_TOKEN_PATH=~/.clawdbot/.linear_token

# Path to Google Analytics OAuth token JSON (default: ~/.clawdbot/.google_analytics_token.json)
# GOOGLE_ANALYTICS_TOKEN_PATH=~/.clawdbot/.google_analytics_token.json

# Base directory for all .clawdbot token files (default: ~/.clawdbot)
# CLAWDBOT_DIR=~/.clawdbot
